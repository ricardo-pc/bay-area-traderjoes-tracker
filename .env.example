SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional scraper tuning.
TJ_AVAILABILITY=1
TJ_PAGE_SIZE=100
TJ_MAX_PAGES=200
TJ_DELAY_MS=750
TJ_REQUEST_TIMEOUT_MS=30000

# Optional comma-separated store slugs to scrape, for example:
# TJ_STORE_SLUGS=trader-joes-university-ave,trader-joes-emeryville

# Set to 1 to print the first Trader Joe's GraphQL response snippet.
DEBUG_TJ=0
